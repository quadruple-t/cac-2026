# Copy this file to .env.local and fill in real values from the Firebase console.
# Project Settings > General for the client config, Project Settings > Service Accounts
# for the admin credentials.

# Client SDK (safe to expose in the browser bundle)
# These also power Firebase AI Logic (lib/firebase/ai.ts). No separate env vars
# needed for that, but the Gemini API must be enabled in the Firebase console
# under Build > AI Logic for this project first.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Admin SDK (server-only, generate a service account key in Firebase console)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the private key with literal \n escapes, e.g. "-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_PRIVATE_KEY=

# 32-byte key, base64-encoded, used for AES-256-GCM field encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEY=

# App Check: enable App Check in the Firebase console (Build > App Check),
# register this web app with the reCAPTCHA v3 provider, and paste its site
# key below. Then flip on enforcement for Authentication (and any other
# products you use) once you've confirmed tokens are being issued.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Optional: in local dev, App Check uses a debug token instead of reCAPTCHA
# (localhost isn't a valid reCAPTCHA domain). Leave unset to auto-generate one
# on each run — it's printed to the browser console the first time; register
# it in Firebase console > App Check > Manage debug tokens. Set this to a
# fixed value instead if you want a stable token across restarts.
NEXT_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN=


# Deadline reminder emails. Configure a scheduler to POST /api/deadline-alerts/send
# with Authorization: Bearer $DEADLINE_ALERT_CRON_SECRET.
DEADLINE_ALERT_CRON_SECRET=
RESEND_API_KEY=
DEADLINE_ALERT_FROM_EMAIL=
